{
	"name": "obsidian-plugin-pulse",
	"version": "0.2.0",
	"description": "Workout tracker and health data importer for Obsidian (obsidian-suite monorepo)",
	"main": "main.js",
	"scripts": {
		"prebuild": "node ../../tooling/merge-css.mjs",
		"dev": "node esbuild.config.mjs",
		"build": "tsc -p tsconfig.json --noEmit && node esbuild.config.mjs production",
		"build:install": "npm run build && node ../../tooling/install-to-vault.mjs .",
		"release": "node ../../tooling/release-plugin.mjs plugins/pulse"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin"
	],
	"author": "Jimmy Little",
	"license": "MIT",
	"dependencies": {
		"@obsidian-suite/heatmap": "*",
		"jszip": "^3.10.1"
	},
	"devDependencies": {
		"@types/node": "^16.18.0",
		"esbuild": "^0.27.0",
		"esbuild-svelte": "^0.9.0",
		"obsidian": "latest",
		"svelte": "^4.2.20",
		"svelte-preprocess": "^6.0.3",
		"tslib": "2.4.0",
		"typescript": "^5.6.0"
	}
}
