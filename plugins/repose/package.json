{
	"name": "obsidian-plugin-repose",
	"version": "0.1.0",
	"description": "Trakt → Obsidian TV/movie notes (obsidian-suite monorepo)",
	"main": "main.js",
	"scripts": {
		"prebuild": "node ../../tooling/merge-css.mjs",
		"dev": "node esbuild.config.mjs",
		"build": "tsc -p tsconfig.json --noEmit && node esbuild.config.mjs production",
		"build:install": "npm run build && node ../../tooling/install-to-vault.mjs .",
		"release": "node ../../tooling/release-plugin.mjs plugins/repose"
	},
	"keywords": ["obsidian", "obsidian-plugin", "trakt"],
	"author": "Jimmy Little",
	"license": "MIT",
	"dependencies": {
		"@obsidian-suite/core": "*",
		"gray-matter": "^4.0.3",
		"monkey-around": "^3.0.0"
	},
	"devDependencies": {
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.40.0",
		"@types/node": "^16.18.0",
		"esbuild": "^0.27.0",
		"esbuild-svelte": "^0.9.0",
		"obsidian": "latest",
		"svelte": "^4.2.20",
		"svelte-preprocess": "^6.0.3",
		"tslib": "2.4.0",
		"typescript": "^5.6.0"
	}
}
